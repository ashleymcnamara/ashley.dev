---
import SocialIcon from './SocialIcon.astro';

interface Social {
    icon: 'github' | 'linkedIn' | 'twitter' | 'email' | 'bluesky';
    link: string;
    title?: string;
    id?: string;
    isEmail?: boolean; // Flag to identify email links
}

const socials: Social[] = [{
    icon: 'github',
    link: 'https://github.com/ashleymcnamara',
    title: 'View GitHub Profile'
}, {
    icon: 'twitter',
    link: 'https://x.com/ashleymcnamara',
    title: 'View Twitter Profile'
}, {
    icon: 'linkedIn',
    link: 'https://www.linkedin.com/in/ashleymcnamara1',
    title: 'View LinkedIn Profile'
}, {
    icon: 'bluesky',
    link: 'https://bsky.app/profile/ashley.dev',
    title: 'View Bluesky Profile'
}, {
    icon: 'email',
    link: 'mailto:hello@ashley.dev',
    title: 'Copy Email Address',
    id: 'email-link',
    isEmail: true
}];

const emailAddress = 'hello@ashley.dev';
---

<!-- Start: Social Links -->
<div class="flex flex-wrap gap-3 mt-6 justify-between">

    {socials.map(social =>
        <a
            href={social.link}
            target={social.isEmail ? undefined : '_blank'}
            title={social.title}
            rel={social.isEmail ? undefined : 'noopener noreferrer'}
            id={social.id}
            aria-label={social.title}
            data-email={social.isEmail ? emailAddress : undefined}
            class={`flex items-center justify-center w-11 h-11 rounded-lg bg-canvas text-text-primary transition-[color,background-color,border-color,transform] duration-150 border border-line-strong hover:bg-primary hover:text-black hover:-translate-y-0.5 ${social.isEmail ? 'email-link' : ''}`}>
            <SocialIcon icon={social.icon} />
        </a>
    )}

</div>
<!-- End: Social Links -->

<p id="email-copy-status" class="sr-only" role="status" aria-live="polite"></p>
<div id="email-copy-toast" class="fixed bottom-5 left-1/2 z-50 -translate-x-1/2 rounded-md bg-primary px-4 py-2.5 text-sm text-black opacity-0 pointer-events-none transition-opacity" aria-hidden="true">
    Email copied to clipboard!
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const emailLink = document.getElementById('email-link');
        const status = document.getElementById('email-copy-status');
        const toast = document.getElementById('email-copy-toast');
        
        if (emailLink) {
            emailLink.addEventListener('click', async (e) => {
                e.preventDefault();
                
                const emailAddress = emailLink.getAttribute('data-email');
                if (!emailAddress) return;

                try {
                    await navigator.clipboard.writeText(emailAddress);
                    if (status) status.textContent = 'Email copied to clipboard.';
                    if (toast) {
                        toast.classList.remove('opacity-0');
                        toast.classList.add('opacity-100');
                        window.setTimeout(() => {
                            toast.classList.remove('opacity-100');
                            toast.classList.add('opacity-0');
                        }, 2000);
                    }
                } catch (err) {
                    console.error('Failed to copy email: ', err);
                    if (status) status.textContent = 'Copy failed. Opening your email application.';
                    window.location.href = `mailto:${emailAddress}`;
                }
            });
        }
    });
</script>
