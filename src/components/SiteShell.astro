---
import Layout from '../layouts/Layout.astro';
import Profile from './Profile.astro';
import Contact from './Contact.astro';

interface Props {
  title: string;
  description?: string;
  active: 'about' | 'projects' | 'speaking' | 'blog';
}

const { title, description, active } = Astro.props as Props;

const tabs = [
  { id: 'about', href: '/', label: 'about.ts' },
  { id: 'projects', href: '/projects', label: 'projects.md' },
  { id: 'speaking', href: '/speaking', label: 'speaking.md' },
  { id: 'blog', href: '/blog', label: 'blog.md' },
];
---

<Layout title={title} description={description}>
  <main class="flex flex-col md:flex-row w-full max-w-full md:max-w-7xl border border-line-strong rounded-2xl overflow-hidden shadow-2xl relative bg-canvas mb-6 mx-auto">
    <div class="p-6 md:p-6 flex flex-col justify-between w-full md:w-2/5 border-b md:border-b-0 md:border-r border-line-strong">
      <Profile isPrimaryHeading={active === 'about'} />
      <Contact />
    </div>

    <div class="w-full md:w-4/5 p-0">
      <div class="min-h-full h-[80vh] sm:h-[85vh] md:h-[90vh] flex flex-col">
        <nav aria-label="Primary" class="flex justify-around bg-canvas border-b border-line-strong sticky top-0 z-10 w-full overflow-x-auto">
          {tabs.map((tab) => (
            <a
              href={tab.href}
              class:list={[
                'tab-link flex min-h-11 items-center gap-0.5 md:gap-1 py-2 px-0.5 md:px-2 text-xs cursor-pointer min-w-[auto] flex-1 justify-center bg-canvas text-text-primary hover:text-primary !border-r !border-r-line-strong',
                active === tab.id && 'border-b-2 border-b-primary text-primary',
              ]}
              aria-current={active === tab.id ? 'page' : undefined}
            >
              <svg class="hidden sm:inline-block flex-shrink-0 w-3.5 h-3.5 md:w-4 md:h-4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
              <span class="whitespace-nowrap text-[0.7rem] sm:text-xs">{tab.label}</span>
            </a>
          ))}
        </nav>

        <div class="p-4 sm:p-6 flex-grow overflow-y-auto bg-canvas h-full">
          <slot />
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .tab-link {
    @apply border-b-2 border-transparent bg-transparent;
    transition: color 0.2s ease-in-out, border-color 0.2s ease-in-out;
  }
</style>
