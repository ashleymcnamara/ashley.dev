---
import { projects } from '../data/projects';
---

<div class="h-full">
    <h1 class="text-3xl md:text-4xl font-bold text-text-primary mb-6">Projects</h1>

    <div class="border-y border-line mb-10 projects-container">
        {projects.map(project => {
            const target = project.link?.target || '_blank';

            return (
            <article class="flex flex-col justify-center items-start py-6 border-b border-line last:border-b-0 project-entry">
                <div class="w-full">
                    <h2 class="text-xl font-semibold text-text-primary mb-2">{project.name}</h2>
                    {project.summary && (
                        <p class="text-sm text-primary">{project.summary}</p>
                    )}
                </div>
                <p class="text-text-muted my-4">{project.description}</p>
                {project.link?.url && (
                    <a
                        href={project.link.url}
                        title={project.link.title || project.name}
                        target={target}
                        rel={target === '_blank' ? 'noopener noreferrer' : undefined}
                        class="inline-flex min-h-11 items-center mt-1 text-primary hover:underline"
                    >
                        {project.link.buttonLabel || 'Open Project Website'} <span aria-hidden="true" class="ml-2">→</span>
                    </a>
                )}
            </article>
            );
        })}
    </div>
</div>

<style>
    /* Ensure projects are properly scrollable on mobile */
    .projects-container {
        min-height: min-content;
        padding-bottom: 1rem;
    }
    
    .project-entry {
        height: auto;
    }
    
    /* Adjust for Safari mobile issues */
    @supports (-webkit-touch-callout: none) {
        .projects-container {
            -webkit-overflow-scrolling: touch;
        }
    }
</style>
