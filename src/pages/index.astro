---
import SiteShell from '../components/SiteShell.astro';
import ContentCode from '../components/ContentAbout.astro';
---

<SiteShell title="Ashley Willis | ashley.dev" active="about">
  <ContentCode />
</SiteShell>

<script>
  // Check if there are any query parameters for compatibility with old URLs
  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const tabParam = urlParams.get('tab');
    const tagParam = urlParams.get('tag');
    
    // Redirect to the appropriate page if a tab parameter exists
    if (tabParam) {
      switch(tabParam) {
        case 'projects':
          window.location.href = '/projects' + (tagParam ? `?tag=${tagParam}` : '');
          break;
        case 'speaking':
          window.location.href = '/speaking' + (tagParam ? `?tag=${tagParam}` : '');
          break;
        case 'blogs':
          window.location.href = '/blog' + (tagParam ? `?tag=${tagParam}` : '');
          break;
        default:
          // If tab=about or unknown tab, stay on this page but clean URL
          if (window.history && window.history.replaceState) {
            window.history.replaceState({}, document.title, window.location.pathname);
          }
      }
    }
  });
</script>
